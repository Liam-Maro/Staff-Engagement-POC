<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                       https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Rename employee_id to individual_id -->
    <changeSet id="010-rename-employee-id-to-individual-id" author="staffengagement">
        <renameColumn tableName="tsk_tasks"
                      oldColumnName="employee_id"
                      newColumnName="individual_id"
                      columnDataType="uuid"/>
    </changeSet>

    <!-- Add creator_id column -->
    <changeSet id="010-add-creator-id" author="staffengagement">
        <addColumn tableName="tsk_tasks">
            <column name="creator_id" type="uuid"/>
        </addColumn>
    </changeSet>

    <!-- Add assignee_id column -->
    <changeSet id="010-add-assignee-id" author="staffengagement">
        <addColumn tableName="tsk_tasks">
            <column name="assignee_id" type="uuid"/>
        </addColumn>
    </changeSet>

    <!-- Drop title column -->
    <changeSet id="010-drop-title-column" author="staffengagement">
        <dropColumn tableName="tsk_tasks" columnName="title"/>
    </changeSet>

    <!-- Backfill null descriptions with empty string -->
    <changeSet id="010-backfill-description-not-null" author="staffengagement">
        <update tableName="tsk_tasks">
            <column name="description" value=""/>
            <where>description IS NULL</where>
        </update>
        <addNotNullConstraint tableName="tsk_tasks"
                              columnName="description"
                              columnDataType="text"/>
    </changeSet>

    <!-- Update status values: OPEN -> TODO, COMPLETED -> DONE -->
    <changeSet id="010-update-status-values" author="staffengagement">
        <update tableName="tsk_tasks">
            <column name="status" value="TODO"/>
            <where>status = 'OPEN'</where>
        </update>
        <update tableName="tsk_tasks">
            <column name="status" value="DONE"/>
            <where>status = 'COMPLETED'</where>
        </update>
    </changeSet>

    <!-- Add FK constraint: creator_id -> stf_staff(id) -->
    <changeSet id="010-add-fk-tsk-creator" author="staffengagement">
        <addForeignKeyConstraint baseTableName="tsk_tasks"
                                 baseColumnNames="creator_id"
                                 constraintName="fk_tsk_creator"
                                 referencedTableName="stf_staff"
                                 referencedColumnNames="id"/>
    </changeSet>

    <!-- Add FK constraint: assignee_id -> stf_staff(id) -->
    <changeSet id="010-add-fk-tsk-assignee" author="staffengagement">
        <addForeignKeyConstraint baseTableName="tsk_tasks"
                                 baseColumnNames="assignee_id"
                                 constraintName="fk_tsk_assignee"
                                 referencedTableName="stf_staff"
                                 referencedColumnNames="id"/>
    </changeSet>

    <!-- Create indexes for query performance -->
    <changeSet id="010-create-task-indexes" author="staffengagement">
        <createIndex indexName="idx_tsk_tasks_assignee_id" tableName="tsk_tasks">
            <column name="assignee_id"/>
        </createIndex>
        <createIndex indexName="idx_tsk_tasks_creator_id" tableName="tsk_tasks">
            <column name="creator_id"/>
        </createIndex>
        <createIndex indexName="idx_tsk_tasks_individual_id" tableName="tsk_tasks">
            <column name="individual_id"/>
        </createIndex>
        <createIndex indexName="idx_tsk_tasks_status" tableName="tsk_tasks">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_tsk_tasks_due_date" tableName="tsk_tasks">
            <column name="due_date"/>
        </createIndex>
        <createIndex indexName="idx_tsk_tasks_created_at" tableName="tsk_tasks">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
